{
  "manifest_version": 3,
  "name": "InclusiveRead",
  "version": "1.0.0",
  "description": "The AI-Powered Cognitive Bridge for Public Web Services - Reducing cognitive friction for neurodivergent users",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "dom-utils.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "include_globs": [
        "*://*/*.pdf",
        "*://*/*.pdf?*",
        "file:///*.pdf"
      ],
      "js": [
        "pdf-content.js"
      ],
      "css": [
        "pdf-content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content.css",
        "pdf-content.css",
        "pdf-content.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}